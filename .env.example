# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored — your real credentials never leave your machine.

# ---- Trello ---------------------------------------------------------------
# From https://trello.com/power-ups/admin → your Power-Up → API key
TRELLO_API_KEY=

# Generate by clicking the "Token" link on the API key page and authorizing.
TRELLO_TOKEN=

# Job Trackers BT MFG board id. Defaults to the BT MFG board if unset.
TRELLO_BOARD_ID=YG0Dh7Kp

# ---- Capacity dashboard (existing /) --------------------------------------
DEFAULT_MIN_PER_CARD=60
HOURS_PER_DAY=8
THRESH_YELLOW_HRS=32
THRESH_RED_HRS=80
PORT=8765

# ---- Value dashboard (new) ------------------------------------------------
# Comma-separated list of Trello list names to EXCLUDE from $ totals (case-
# insensitive). These are the "done / out the door" buckets.
EXCLUDE_LISTS=Shipped,Done,Complete,Archived,Archive

# Optional: local folder full of Sun PO PDFs. Checked before hitting Gmail
# so common cases stay fast (and work offline). Leave blank to skip.
LOCAL_PO_DIR=/Users/ben/Library/CloudStorage/OneDrive-Personal/Documents/BT Manufacturing Files/Operations/Purchase Orders

# Password the public GitHub Pages dashboard prompts for. Leave blank to
# disable the prompt (the URL is still obscure, but anyone with it sees
# everything).
DASHBOARD_PASSWORD=
